# DeepSeek4Free uses an authenticated DeepSeek web-session token. Never commit it.
DEEPSEEK_AUTH_TOKEN=
# Optional when the repository lives outside backend/.vendor/deepseek4free
DEEPSEEK4FREE_PATH=
# Enables deterministic demo translations when no token is present. Keep false in production.
DEMO_TRANSLATOR=false
# Comma separated origins for browser clients. Leave blank during local development.
CORS_ORIGINS=http://localhost:5173
DATABASE_PATH=./talkrealtime.db
